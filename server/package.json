{
  "name": "@notes/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "set-passcode": "tsx src/cli/set-passcode.ts",
